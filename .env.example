# PostgreSQL (Docker Compose)
POSTGRES_USER=beljot
POSTGRES_PASSWORD=beljot_dev_password
POSTGRES_DB=beljot

# Application
BELJOT_DB_URL=postgres://beljot:beljot_dev_password@localhost:5433/beljot?sslmode=disable
BELJOT_JWT_SECRET=change-me-in-production
BELJOT_PORT=8080
BELJOT_CORS_ORIGINS=http://localhost:5173
BELJOT_ENV=development

# Public frontend origin, used to build links in outgoing email (no trailing slash).
# Dev: http://localhost:5173 — Prod: https://beljot.online
BELJOT_APP_BASE_URL=http://localhost:5173

# Email / SMTP (password-reset and other transactional mail).
# Leave HOST/USERNAME/PASSWORD blank to fall back to logging the reset link to
# stdout instead of sending — handy in dev without real credentials.
# Gmail: host=smtp.gmail.com, port=587 (STARTTLS), username=<full address>,
# password=<16-char Google "App password", NOT your account password>.
BELJOT_SMTP_HOST=
BELJOT_SMTP_PORT=587
BELJOT_SMTP_USERNAME=
BELJOT_SMTP_PASSWORD=
BELJOT_SMTP_FROM=you@example.com
BELJOT_SMTP_FROM_NAME=Beljot.online

# Production-only (set in /opt/beljot/.env on the VPS, never commit real values)
# IMAGE_TAG=<git-sha, set by deploy workflow>
# ACME_EMAIL=you@example.com
# CLOUDFLARE_API_TOKEN=<token with Zone:DNS:Edit + Zone:Zone:Read on beljot.online>
